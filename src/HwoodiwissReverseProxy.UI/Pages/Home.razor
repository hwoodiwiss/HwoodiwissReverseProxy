@page "/"
@inject ProxyApiClient Api

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>
<p>Overview of the current reverse proxy configuration.</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_loading)
{
    <div class="d-flex align-items-center gap-2 text-muted">
        <div class="spinner-border spinner-border-sm" role="status"></div>
        Loading configuration...
    </div>
}
else
{
    <div class="row g-3">
        <div class="col-sm-6 col-md-4">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted mb-1" style="font-size:0.8125rem;text-transform:uppercase;letter-spacing:0.05em;font-weight:600;">Routes</div>
                    <div style="font-size:2rem;font-weight:700;color:var(--app-accent);">@_routeCount</div>
                    <a href="routes" class="stretched-link" style="font-size:0.875rem;">View routes &rarr;</a>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-md-4">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted mb-1" style="font-size:0.8125rem;text-transform:uppercase;letter-spacing:0.05em;font-weight:600;">Clusters</div>
                    <div style="font-size:2rem;font-weight:700;color:var(--app-accent);">@_clusterCount</div>
                    <a href="clusters" class="stretched-link" style="font-size:0.875rem;">View clusters &rarr;</a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private int _routeCount;
    private int _clusterCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var routes = await Api.GetRoutesAsync();
            var clusters = await Api.GetClustersAsync();
            _routeCount = routes?.Count ?? 0;
            _clusterCount = clusters?.Count ?? 0;
        }
        catch (Exception ex)
        {
            _error = $"Failed to load configuration: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}
